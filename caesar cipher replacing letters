#include <stdio.h>
#include <ctype.h>
int main() {
    char text[100];
    int shift, i;
    printf("Enter a message: ");
    gets(text);
    printf("Enter shift value: ");
    scanf("%d", &shift);
    for(i = 0; text[i] != '\0'; i++) {
        if(isalpha(text[i])) {
            char base;
            if(isupper(text[i]))
                base = 'A';
            else
                base = 'a';

            text[i] = (text[i] - base + shift) % 26 + base;
        }
    }
    printf("Encrypted message: %s", text);
    return 0;
}
