plaintext = input("Enter plaintext: ")
key = input("Enter 26-letter substitution key: ")

alphabet = "abcdefghijklmnopqrstuvwxyz"
ciphertext = ""

for char in plaintext:
    if char.isalpha():
        index = alphabet.index(char.lower())
        cipher = key[index]
        ciphertext += cipher
    else:
        ciphertext += char

print("Ciphertext:", ciphertext)
